# Env for the agent edge functions. Copy to .env.local (gitignored) for
# `supabase functions serve`, or set in production with `supabase secrets set`.
#
# NOTE: the WhatsApp credentials are NOT env vars — they live encrypted in
# Supabase Vault and agent-whatsapp reads them via the get_whatsapp_secrets()
# RPC (migration 20260607130000). Store/rotate them in Vault, e.g.:
#   select vault.create_secret('<value>', 'WHATSAPP_ACCESS_TOKEN', '...');
# Vault names used: WHATSAPP_ACCESS_TOKEN, WHATSAPP_PHONE_NUMBER_ID,
#                   WHATSAPP_VERIFY_TOKEN, WHATSAPP_APP_SECRET.

# ── WhatsApp (non-secret infra only) ─────────────────────────────────────────
# Optional, defaults to v23.0:
# WHATSAPP_GRAPH_VERSION=v23.0

# ── Agent core ───────────────────────────────────────────────────────────────
OPENAI_API_KEY=
# Optional, defaults to gpt-4o-mini:
# OPENAI_MODEL=gpt-4o-mini

# ── Web chat (agent-chat) ────────────────────────────────────────────────────
# Comma-separated allowed origins for CORS.
AGENT_CHAT_ALLOWED_ORIGINS=
