NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_or_legacy_anon_key
SUPABASE_SERVICE_ROLE_KEY=server_only_service_role_key

# HeroUI Pro CI token. Generate at https://heroui.pro/dashboard.
# Read by @heroui-pro/react postinstall; required for `npm install` on CI.
HEROUI_AUTH_TOKEN=

# MapTiler key — satellite basemap for the LoteCarousel SharedMap.
# Restrict to your prod domain in the MapTiler dashboard before shipping.
NEXT_PUBLIC_MAPTILER_KEY=

# ─── AI ordering agent (Supabase Edge Functions) ──────────────────────────────
# These are set as SUPABASE secrets for the edge functions, NOT used by Next.js.
# Set them with: supabase secrets set OPENAI_API_KEY=... TELEGRAM_BOT_TOKEN=... etc.
#
# OpenAI API key — powers the agent (Vercel AI SDK + @ai-sdk/openai).
OPENAI_API_KEY=sk-...
# Telegram bot token from @BotFather — agent-telegram function uses it to reply.
TELEGRAM_BOT_TOKEN=
# Shared secret you choose; set it both here and in setWebhook's secret_token so
# the agent-telegram function can verify the X-Telegram-Bot-Api-Secret-Token header.
TELEGRAM_WEBHOOK_SECRET=
# Comma-separated origins allowed to call the agent-chat web endpoint (CORS).
AGENT_CHAT_ALLOWED_ORIGINS=http://localhost:3000
# NOTE: SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are injected automatically
# into edge functions by the platform; no need to set them as secrets.
